<Window x:Class="WheelMenu.Windows.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="轮盘测试窗口"
        Width="400"
        Height="350"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="操作说明：" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="Space - 弹出圆盘" Margin="10,0,0,4"/>
            <TextBlock Text="Escape - 关闭圆盘" Margin="10,0,0,4"/>
            <TextBlock Text="1~8 - 高亮内圈" Margin="10,0,0,4"/>
            <TextBlock Text="Q + 1~8 - 高亮外圈" Margin="10,0,0,4"/>
            <TextBlock Text="F1 - 切换隐藏文字" Margin="10,0,0,4"/>
            <TextBlock Text="F2 - 切换16格模式" Margin="10,0,0,4"/>
            <TextBlock Text="F3 - 右上角测试" Margin="10,0,0,4"/>
            <TextBlock Text="F4 - 左下角测试" Margin="10,0,0,20"/>
            
            <Button Content="打开设置窗口" Width="120" Height="30" Click="OnOpenSettings"/>
        </StackPanel>
    </Grid>
</Window>
