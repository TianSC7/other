<Window x:Class="WheelMenu.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:renderer="clr-namespace:WheelMenu.Renderer"
        Title="轮盘菜单设置"
        Width="1000"
        Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="Center" 
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>
        
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航栏 -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <StackPanel>
                <TextBlock Text="轮盘设置" FontSize="18" FontWeight="Bold" Margin="15,20,15,25" Foreground="#2196F3"/>
                <Button x:Name="NavSettings" Content="基本设置" Click="OnNavSettings" Style="{StaticResource NavButtonStyle}"/>
                <Button x:Name="NavActions" Content="动作管理" Click="OnNavActions" Style="{StaticResource NavButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- 右侧内容区 -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <Grid>
                <!-- 轮盘菜单设置页 -->
                <StackPanel x:Name="SettingsPanel" Visibility="Visible" MaxWidth="600" HorizontalAlignment="Left">
                    
                    <!-- 触发设置 -->
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="触发设置" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,15"/>
                            
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="触发按键：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                <ComboBox x:Name="TriggerKeyCombo" Grid.Column="1" Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="鼠标中键（滚轮键）" Tag="middle"/>
                                    <ComboBoxItem Content="鼠标侧键 X1（后退键）" Tag="x1"/>
                                    <ComboBoxItem Content="鼠标侧键 X2（前进键）" Tag="x2"/>
                                    <ComboBoxItem Content="侧滚轮" Tag="side_scroll"/>
                                </ComboBox>
                            </Grid>
                            
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="轮盘尺寸：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Slider x:Name="SizeSlider" Width="150" Minimum="50" Maximum="300" Value="200" />
                                    <TextBox x:Name="SizeTextBox" Width="50" Margin="10,0,0,0" Padding="5,3" 
                                             TextAlignment="Center" Text="200"/>
                                    <TextBlock Text="像素" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="超时时间：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBox x:Name="TimeoutTextBox" Width="80" Padding="5,3" Text="3000"/>
                                    <TextBlock Text="毫秒" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- 功能开关 -->
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="功能开关" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,15"/>
                            
                            <CheckBox x:Name="OuterRing16Check" Content="外圈16格模式" Margin="0,0,0,8"/>
                            <CheckBox x:Name="HideLabelCheck" Content="有图标时隐藏文字" Margin="0,0,0,8"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- 屏幕边缘 -->
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="屏幕边缘" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,15"/>
                            
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="边缘限制：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                <ComboBox x:Name="ConstrainScreenCombo" Grid.Column="1" Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="不限制" Tag="None"/>
                                    <ComboBoxItem Content="主屏幕" Tag="Primary"/>
                                    <ComboBoxItem Content="光标所在屏幕" Tag="Cursor"/>
                                </ComboBox>
                            </Grid>
                            
                            <CheckBox x:Name="AutoMoveCursorCheck" Content="自动移动光标到中心"/>
                            
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="重复触发：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                <TextBox x:Name="RepeatKeyTextBox" Grid.Column="1" Width="150" HorizontalAlignment="Left" Padding="5,3"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- 场景列表 -->
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="场景列表" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,15"/>
                            
                            <ListBox x:Name="SceneListBox" Height="120" Margin="0,0,0,10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Padding="5,3"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Content="+ 添加场景" Margin="10" Padding="10" Click="OnAddScene"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- 保存按钮 -->
                    <Button Content="保存设置" Width="120" Height="36" Background="#4CAF50" Foreground="White" 
                            HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnSaveSettings"/>
                </StackPanel>
                
                <!-- 动作管理页 -->
                <Grid x:Name="ActionsPanel" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="400"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 左侧动作页面（4x4网格）- 放上面 -->
                    <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                            CornerRadius="8" Margin="0,0,10,0" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 动作页面标题和添加按钮 -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock x:Name="SlotInfoText" Text="动作页面" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Button Content="＋ 添加动作页" Margin="15,0,0,0" Padding="10,5" Click="OnAddActionPage"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- 动作页面垂直滚动区域 -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="500">
                                <StackPanel x:Name="ActionPagesPanel">
                                    <!-- 多个动作页面将垂直排列 -->
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    
                    <!-- 右侧轮盘示意图 - 放下面 -->
                    <Border Grid.Column="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                            CornerRadius="8" Padding="20">
                        <Grid>
                            <renderer:DiskUIControl x:Name="WheelPreviewCanvas" Width="340" Height="340" 
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                AllowDrop="True"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
