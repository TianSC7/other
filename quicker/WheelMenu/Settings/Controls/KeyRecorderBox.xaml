<UserControl x:Class="WheelMenu.Settings.Controls.KeyRecorderBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="BorderBox"
            BorderBrush="Gray" BorderThickness="1"
            Background="White" Padding="8,6"
            CornerRadius="4"
            Cursor="Hand">
        <TextBlock x:Name="DisplayTextBlock"
                   Text="{Binding KeyText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="Black"
                   FontSize="12"
                   VerticalAlignment="Center"/>
    </Border>
</UserControl>
